# ── Project ─────────────────────────────────────────────────────────────────
# Used to name images, Docker volumes, and Docker networks.
COMPOSE_PROJECT_NAME=hapi-fhir_poc

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=hapi
POSTGRES_USER=user
# IMPORTANT: Change this to a strong password for any non-local deployment.
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=changeme

# ── HAPI FHIR ───────────────────────────────────────────────────────────────
# Optional: override when accessing HAPI from a non-localhost hostname or port.
# The Tester UI will use this address to connect to the FHIR server.
# Example for remote access: http://192.168.1.100:8080/fhir
# HAPI_TESTER_SERVER_ADDRESS=http://localhost:8080/fhir
